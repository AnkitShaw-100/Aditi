APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173
FORCE_HTTPS=false
ADMIN_COOKIE_NAME=aditi_admin
ADMIN_COOKIE_SECURE=false
ADMIN_COOKIE_SAMESITE=Lax

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=aditi
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# Use your Clerk Frontend API JWKS URL, for example:
# https://your-clerk-frontend-api.clerk.accounts.dev/.well-known/jwks.json
# Clerk also documents https://api.clerk.com/v1/jwks as a JWKS source.
CLERK_JWKS_URL=

# Optional but recommended. Example:
# https://your-clerk-frontend-api.clerk.accounts.dev
CLERK_ISSUER=

# Comma-separated frontend origins allowed to mint tokens for this backend.
# Example: http://localhost:5173,https://aditi.example.com
CLERK_AUTHORIZED_PARTIES=http://localhost:5173

# Optional. If present, the backend fetches verified profile fields from Clerk.
CLERK_SECRET_KEY=

# Clerk Dashboard -> Webhooks -> your endpoint -> Signing Secret.
# This is only needed for POST /api/webhooks/clerk.
CLERK_WEBHOOK_SECRET=

# Razorpay Dashboard -> Account & Settings -> API keys.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Razorpay Dashboard -> Developers -> Webhooks -> your endpoint -> Secret.
# This is needed for POST /api/webhooks/razorpay.
RAZORPAY_WEBHOOK_SECRET=

MAIL_ENABLED=false
MAIL_MAILER=mail
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="ADITI"
